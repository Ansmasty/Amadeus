# Ollama endpoint
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# Directorios permitidos (separados por coma)
ALLOWED_BASE_DIRS=C:/Users/TU_USUARIO/Desktop,C:/Users/TU_USUARIO/Documents

# Tamaño máximo de archivo a leer (MB)
MAX_FILE_READ_MB=100

# Título de la app
APP_TITLE=AMADEUS

# ─── Configuración de Voz ──────────────────────────────────────────────────
# Idioma para reconocimiento de voz
# Google: "es-ES", "es-MX", "en-US" | Whisper: "es", "en"
VOICE_LANGUAGE=es-ES

# Usar Whisper offline en lugar de Google (requiere faster-whisper)
# true = 100% offline | false = usa Google (requiere internet)
USE_WHISPER=false

# Tamaño del modelo Whisper: tiny, base, small, medium, large
WHISPER_MODEL=base

# Velocidad de lectura TTS (palabras por minuto, recomendado: 150-180)
TTS_RATE=165

# Volumen TTS (0.0 - 1.0)
TTS_VOLUME=1.0
